    },
    "url": {
      "type": "string"
    },
    "secret": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "activity_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "activity_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "member_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
