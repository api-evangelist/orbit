{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://orbit.love/schemas/webhook_subscription.json",
  "title": "Webhook Subscription",
  "description": "Orbit webhook_subscription schema",
  "type": "object",
