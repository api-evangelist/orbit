  "$id": "https://orbit.love/schemas/alert.json",
  "title": "Alert",
  "description": "Orbit alert schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "activity_types": {
